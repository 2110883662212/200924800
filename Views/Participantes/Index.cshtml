@model IEnumerable<RegistroEventos.Models.Participante>
@{
    ViewData["Title"] = "Lista de Participantes";
    var talleres = ViewBag.Talleres as List<RegistroEventos.Models.Taller>;
}

@if (TempData["Notificacion"] != null)
{
    <div class="alert alert-success alert-dismissible fade show mt-3" role="alert">
        <strong>@TempData["Notificacion"]</strong>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="d-flex justify-content-between align-items-center mt-4 mb-3">
    <h2>Participantes Registrados</h2>
    <a asp-action="Inscribir" class="btn btn-primary">Nueva Inscripción</a>
</div>

<table class="table table-striped table-bordered">
    <thead class="table-dark">
        <tr>
            <th>ID</th>
            <th>Nombre</th>
            <th>Correo</th>
            <th>Taller Asignado</th>
            <th>Modalidad</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        @if (!Model.Any())
        {
            <tr>
                <td colspan="6" class="text-center text-muted">No hay participantes registrados todavía.</td>
            </tr>
        }
        else
        {
            foreach (var item in Model)
            {
                <tr>
                    <td>@item.Id</td>
                    <td>@item.Nombre</td>
                    <td>@item.Correo</td>
                    <td>@(talleres?.FirstOrDefault(t => t.Id == item.TallerId)?.Nombre ?? "Desconocido")</td>
                    <td>
                        <span class="badge @(item.TipoEntrada == "Presencial" ? "bg-info" : "bg-warning text-dark")">
                            @item.TipoEntrada
                        </span>
                    </td>
                    <td>
                        <a asp-action="Confirmacion" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">
                            📄 Ver Comprobante (PDF-Style)
                        </a>
                    </td>
                </tr>
            }
        }
    </tbody>
</table>